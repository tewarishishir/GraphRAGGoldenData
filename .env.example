# Neo4j connection (required for neo4j_kg.py and the web app)
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Optional: Neo4j Aura uses NEO4J_USERNAME; local may use NEO4J_USER
# NEO4J_USER=neo4j

# Optional: Neo4j Aura database (instance id)
# NEO4J_DATABASE=neo4j

# Optional: Masking script reproducibility (scripts/mask_data_for_github.py)
# MASK_SALT=your-secret-salt

# Optional: Ollama for natural-language Ask (graph_rag.py)
# OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434
